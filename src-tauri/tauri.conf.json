{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sesh",
  "version": "0.1.0",
  "identifier": "com.sesh.terminal",
  "build": { "beforeDevCommand": "npm run dev", "devUrl": "http://localhost:1420", "beforeBuildCommand": "npm run build", "frontendDist": "../dist" },
  "app": {
    "windows": [{ "title": "sesh", "width": 1200, "height": 780, "minWidth": 760, "minHeight": 540, "transparent": true, "decorations": true }],
    "security": { "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost ws://127.0.0.1:*" }
  },
  "bundle": { "active": true, "targets": "all", "category": "DeveloperTool", "shortDescription": "A focused, customizable SSH client" }
}
